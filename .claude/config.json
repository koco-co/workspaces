{
  "project": {
    "name": "qa-flow",
    "displayName": "qa-flow"
  },
  "casesRoot": "cases/",
  "casesTypes": ["prds", "archive", "xmind", "issues", "history"],
  "modules": {
    "data-assets": {
      "zh": "数据资产",
      "trackerId": 23
    }
  },
  "repos": {},
  "stackTrace": {},
  "branchMapping": "config/repo-branch-mapping.yaml",
  "trash": {
    "dir": ".trash/",
    "retentionDays": 30
  },
  "assets": {
    "images": "assets/images/"
  },
  "reports": {
    "bugs": "reports/bugs/",
    "conflicts": "reports/conflicts/"
  },
  "integrations": {
    "zentao": {
      "baseUrl": "http://zenpms.dtstack.cn",
      "version": "12.3.3",
      "fetchScript": ".claude/shared/scripts/fetch-zentao-bug.mjs"
    },
    "lanhuMcp": {
      "runtimePath": "tools/lanhu-mcp/",
      "setupScript": "tools/lanhu-mcp/setup-env.sh",
      "quickstartScript": "tools/lanhu-mcp/quickstart.sh",
      "entryScript": "tools/lanhu-mcp/lanhu_mcp_server.py",
      "serverHost": "127.0.0.1",
      "serverPort": 8000,
      "serverUrl": "http://127.0.0.1:8000",
      "mcpPath": "/mcp",
      "logFile": ".claude/tmp/lanhu-mcp.log",
      "cookieRefreshScript": ".claude/skills/using-qa-flow/scripts/refresh-lanhu-cookie.py"
    }
  }
}
