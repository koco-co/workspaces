# ══════════════════════════════════════════════════════════════════════════════
# qa-flow 统一配置文件
# 使用方法：复制本文件为 .env 并填入实际值
# ⚠️ .env 文件包含敏感信息，已加入 .gitignore，请勿提交
# ══════════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────
# 钉钉机器人 Webhook（不配置则跳过）
# 文档：https://open.dingtalk.com/document/robots/custom-robot-access
# ──────────────────────────────────────────────
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN
# 安全设置（二选一）：
# 方式一：关键词安全 — 机器人后台设置了关键词时必填，自动追加到消息标题
DINGTALK_KEYWORD=qa-flow
# 方式二：加签安全 — 机器人后台选「加签」时必填，自动计算 HMAC-SHA256 签名
DINGTALK_SIGN_SECRET=

# ──────────────────────────────────────────────
# 飞书机器人 Webhook（不配置则跳过）
# 文档：https://open.feishu.cn/document/client-docs/bot-v3/add-custom-bot
# ──────────────────────────────────────────────
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_HOOK_ID

# ──────────────────────────────────────────────
# 企业微信机器人 Webhook（不配置则跳过）
# 文档：https://developer.work.weixin.qq.com/document/path/91770
# ──────────────────────────────────────────────
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY

# ──────────────────────────────────────────────
# SMTP 邮件通知（SMTP_HOST + SMTP_USER 同时配置才启用）
# 文档：https://nodemailer.com/smtp/
# ──────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=user@example.com
SMTP_PASS=your_password
SMTP_FROM=qa-flow <user@example.com>
SMTP_TO=team@example.com

# ──────────────────────────────────────────────
# 禅道项目管理（用于 Bug 链接自动转化）
# 文档：http://zenpms.dtstack.cn/zentao/doc-view-xxx.html
# ──────────────────────────────────────────────
# 禅道服务地址（默认已内置到 config.json，如需覆盖在此设置）
ZENTAO_BASE_URL=http://zenpms.dtstack.cn
# 禅道登录账号
ZENTAO_ACCOUNT=your_account
# 禅道登录密码
ZENTAO_PASSWORD=your_password

# ──────────────────────────────────────────────
# 蓝湖 MCP 服务（用于需求文档导入）
# 获取 Cookie 方法参见：tools/lanhu-mcp/GET-COOKIE-TUTORIAL.md
# ──────────────────────────────────────────────
# 蓝湖登录 Cookie（登录蓝湖网页版后从浏览器开发者工具复制）
LANHU_COOKIE=your_lanhu_cookie_here

# ──────────────────────────────────────────────
# Git 远程仓库信息（用于通知消息中的链接）
# ──────────────────────────────────────────────
# 远程仓库 URL（示例：https://github.com/your-org/qa-flow）
GIT_REMOTE_URL=https://github.com/koco-co/qa-flow.git

# ──────────────────────────────────────────────
# 服务器路径（用于通知消息中的绝对路径）
# 填入本机 qa-flow 仓库的完整绝对路径（不带末尾斜杠）
# ──────────────────────────────────────────────
SERVER_WORKSPACE_PATH=/path/to/qa-flow

# ──────────────────────────────────────────────
# 源码仓库分支映射文件路径（相对于仓库根目录）
# 仅在使用源码仓库同步功能时配置（config.repos 非空时）
# ──────────────────────────────────────────────
REPO_BRANCH_MAPPING_PATH=.claude/repo-branch-mapping.yaml
