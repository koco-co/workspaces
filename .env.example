# ══════════════════════════════════════════════════════════════════════════════
# kata 核心配置 + 插件凭证模板
# 复制本文件为 .env 并填入实际值。.env 已加入 .gitignore
#
# 加载顺序（高 → 低）：.env.local > .env.envs > .env > process.env
# 多环境段（LTQC* / CI63* / ACTIVE_ENV 等）独立放在 .env.envs（复制 .env.envs.example）
# ══════════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────
# 核心配置
# ──────────────────────────────────────────────
# 工作区目录（默认 workspace）
WORKSPACE_DIR=workspace

# 源码仓库列表（逗号分隔 git URL，可留空）
SOURCE_REPOS=

# 默认项目名称（可选，多项目时推荐显式 --project）
PROJECT_NAME=

# 远程仓库 URL（用于通知消息中的链接）
GIT_REMOTE_URL=

# 本机 kata 仓库绝对路径
SERVER_WORKSPACE_PATH=

# 源码仓库分支映射文件路径
REPO_BRANCH_MAPPING_PATH=config/repo-branch-mapping.yaml

# ──────────────────────────────────────────────
# 钉钉机器人 Webhook（不配置则跳过）
# ──────────────────────────────────────────────
DINGTALK_WEBHOOK_URL=
DINGTALK_KEYWORD=kata
DINGTALK_SIGN_SECRET=

# ──────────────────────────────────────────────
# 飞书机器人 Webhook（不配置则跳过）
# ──────────────────────────────────────────────
FEISHU_WEBHOOK_URL=

# ──────────────────────────────────────────────
# 企业微信机器人 Webhook（不配置则跳过）
# ──────────────────────────────────────────────
WECOM_WEBHOOK_URL=

# ──────────────────────────────────────────────
# SMTP 邮件通知
# ──────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=

# ──────────────────────────────────────────────
# 禅道项目管理（用于 Bug 链接自动转化）
# ──────────────────────────────────────────────
ZENTAO_BASE_URL=
ZENTAO_ACCOUNT=
ZENTAO_PASSWORD=

# ──────────────────────────────────────────────
# 蓝湖 MCP 服务（用于需求文档导入）
# 获取 Cookie 方法参见：plugins/lanhu/mcp-bridge/GET-COOKIE-TUTORIAL.md
# ──────────────────────────────────────────────
LANHU_COOKIE=
LANHU_USERNAME=
LANHU_PASSWORD=
