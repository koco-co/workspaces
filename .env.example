# ══════════════════════════════════════════════
# qa-flow v2.0 统一配置
# 复制为 .env 并填入实际值。.env 已加入 .gitignore
# ══════════════════════════════════════════════

# 核心
WORKSPACE_DIR=workspace

# 源码仓库（逗号分隔 git URL，可留空）
SOURCE_REPOS=

# ── 插件配置（填了即启用） ──

# 蓝湖 PRD 导入
LANHU_COOKIE=

# 禅道 Bug 集成
ZENTAO_BASE_URL=
ZENTAO_ACCOUNT=
ZENTAO_PASSWORD=

# IM 通知（至少配一个通道即启用 notify 插件）
DINGTALK_WEBHOOK_URL=
DINGTALK_KEYWORD=qa-flow
FEISHU_WEBHOOK_URL=
WECOM_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=
