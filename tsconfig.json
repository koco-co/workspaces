{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": ".",
    "paths": {
      "@e2e/*": ["tests/e2e/*"],
      "@pw/*": ["lib/playwright/*"]
    },
    "types": ["node"]
  },
  "include": [
    ".claude/skills/**/*.ts",
    "plugins/**/*.ts",
    "tests/**/*.ts",
    "lib/**/*.ts"
  ],
  "exclude": ["node_modules", "workspace"]
}
