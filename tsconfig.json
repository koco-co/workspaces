{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2024"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "declaration": false,
    "noEmit": true,
    "baseUrl": ".",
    "rootDir": ".",
    "paths": {
      "@e2e/*": ["tests/e2e/*"]
    },
    "types": ["node"]
  },
  "include": [
    ".claude/scripts/**/*.ts",
    ".claude/skills/**/*.ts",
    "plugins/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": ["node_modules", "workspace"]
}
