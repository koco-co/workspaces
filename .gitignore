# ── 依赖 ────────────────────────────────────────────────
node_modules/
.venv/

# ── 环境与敏感配置 ────────────────────────────────────────
.env
.env.envs
.env.local
.auth/
config.json
config/repo-branch-mapping.yaml
plugins/assets-sql-sync/src/config/datasources.yaml

# ── 源码仓库（submodule 引用） ────────────────────────────
*.repos/

# ── 工作区临时文件 ────────────────────────────────────────
.temp/

# ── kata 进度引擎运行时数据 ───────────────────────────
.kata/

# ── Playwright 自动生成产物 ─────────────────────────────
test-results/
playwright-report/
.playwright-cli

# ── 调试 / 临时 spec 兜底（F1）─────────────────────────────
t*-debug.spec.ts
*-repro.spec.ts
diag_*.spec.ts
/.debug/

# ── workspace 内运行时产物（§3.4 F6）─────────────────────
workspace/*/.runs/

# ── 测试报告产物（Allure/Bug/Playwright HTML，不入库） ──
workspace/*/reports/allure/
workspace/*/reports/bugs/
workspace/*/reports/playwright/

# ── 编译 / 构建产物 ─────────────────────────────────────
dist/
*.tsbuildinfo

# ── 自动生成的计划文档 ──────────────────────────────────
docs/superpowers/
docs/plans/

# ── IDE / 编辑器 ──────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Claude Code 本地配置 ──────────────────────────────────
.claude/settings.json

# ── Python ─────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── 操作系统 ────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── 日志 ────────────────────────────────────────────────
*.log

# ── 保留 workspace 目录结构 ─────────────────────────────
!workspace/.gitkeep
