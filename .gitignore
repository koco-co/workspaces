# ── 依赖 ────────────────────────────────────────────────
node_modules/

# ── 环境配置 ────────────────────────────────
.env
.auth/

# ── 源码仓库 ────────────────────────────
workspace/.repos/
!workspace/.repos/**/.gitkeep

# ── Playwright 自动生成产物 ─────────────────────────────
test-results/
playwright-report/
workspace/reports/playwright/
workspace/reports/bugs/

# ── 临时文件 ────────────────────────────────────────────
.temp/
workspace/.temp/
.trash/

# ── 编译 / 构建产物 ─────────────────────────────────────
dist/
*.tsbuildinfo

# ── Python ─────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── 操作系统 ────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── 日志 ────────────────────────────────────────────────
*.log

# ── 保留 workspace 目录结构 ─────────────────────────────
!workspace/.gitkeep
