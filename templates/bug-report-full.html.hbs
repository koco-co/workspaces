<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}} - Bug 分析报告</title>
  <style>
    :root {
      --bg: #f8f9fa;
      --card: #ffffff;
      --border: #e2e8f0;
      --text: #1a202c;
      --text-secondary: #64748b;
      --primary: #3b82f6;
      --critical: #ef4444;
      --warning: #f59e0b;
      --success: #22c55e;
      --code-bg: #1e293b;
      --code-text: #e2e8f0;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
      padding: 24px;
    }
    .container { max-width: 960px; margin: 0 auto; }

    /* Header */
    .header {
      background: linear-gradient(135deg, #1e293b 0%, #334155 100%);
      color: #fff;
      border-radius: 12px;
      padding: 32px;
      margin-bottom: 24px;
    }
    .header h1 { font-size: 22px; margin-bottom: 12px; font-weight: 600; }
    .header-meta { display: flex; gap: 24px; flex-wrap: wrap; font-size: 13px; opacity: 0.85; }
    .header-meta span { display: flex; align-items: center; gap: 6px; }

    /* Badges */
    .badge {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
      color: #fff;
    }
    .badge-critical { background: var(--critical); }
    .badge-major    { background: #ea580c; }
    .badge-normal   { background: var(--warning); }
    .badge-low      { background: #6b7280; }
    .badge-code     { background: var(--primary); }
    .badge-env      { background: var(--success); }
    .badge-mix      { background: #8b5cf6; }

    /* Cards */
    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 24px;
      margin-bottom: 20px;
    }
    .card-title {
      font-size: 16px;
      font-weight: 600;
      margin-bottom: 16px;
      padding-bottom: 10px;
      border-bottom: 2px solid var(--primary);
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .card-title .icon { font-size: 18px; }

    /* Summary */
    .summary-box {
      background: #fef2f2;
      border-left: 4px solid var(--critical);
      padding: 16px 20px;
      border-radius: 0 8px 8px 0;
      margin-bottom: 20px;
      font-size: 15px;
    }

    /* Code blocks */
    pre {
      background: var(--code-bg);
      color: var(--code-text);
      border-radius: 8px;
      padding: 16px;
      overflow-x: auto;
      font-family: "JetBrains Mono", "Fira Code", Menlo, monospace;
      font-size: 13px;
      line-height: 1.7;
      margin: 12px 0;
    }
    .line-highlight {
      background: rgba(239, 68, 68, 0.25);
      display: block;
      margin: 0 -16px;
      padding: 0 16px;
      border-left: 3px solid var(--critical);
    }
    .line-num {
      color: #64748b;
      display: inline-block;
      width: 32px;
      text-align: right;
      margin-right: 16px;
      user-select: none;
    }

    /* Call chain */
    .chain { list-style: none; }
    .chain li {
      position: relative;
      padding: 10px 16px 10px 32px;
      border-left: 2px solid var(--border);
      font-size: 13px;
      font-family: monospace;
    }
    .chain li:last-child { border-left-color: var(--critical); }
    .chain li::before {
      content: '';
      position: absolute;
      left: -6px;
      top: 14px;
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--border);
      border: 2px solid var(--card);
    }
    .chain li:last-child::before { background: var(--critical); }
    .chain li.entry::before { background: var(--primary); }

    /* Fix suggestions */
    .fix-item {
      padding: 16px;
      border: 1px solid var(--border);
      border-radius: 8px;
      margin-bottom: 12px;
      transition: box-shadow 0.2s;
    }
    .fix-item:hover { box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
    .fix-item h4 {
      font-size: 14px;
      margin-bottom: 8px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .fix-item p { font-size: 13px; color: var(--text-secondary); margin-bottom: 4px; }
    .priority-tag {
      font-size: 11px;
      padding: 1px 8px;
      border-radius: 4px;
      font-weight: 600;
    }
    .p1 { background: #fef2f2; color: var(--critical); }
    .p2 { background: #fffbeb; color: #b45309; }
    .p3 { background: #f0fdf4; color: #15803d; }

    /* Request table */
    .req-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .req-table td { padding: 8px 12px; border-bottom: 1px solid var(--border); vertical-align: top; }
    .req-table td:first-child {
      font-weight: 600;
      width: 100px;
      color: var(--text-secondary);
      white-space: nowrap;
    }
    .req-table td:last-child { word-break: break-all; }

    /* Risk box */
    .risk-box {
      background: #fffbeb;
      border-left: 4px solid var(--warning);
      padding: 16px 20px;
      border-radius: 0 8px 8px 0;
      margin: 12px 0;
      font-size: 13px;
    }
    .risk-box strong { color: #b45309; }

    /* Footer */
    .footer {
      text-align: center;
      padding: 20px;
      color: var(--text-secondary);
      font-size: 12px;
    }
  </style>
</head>
<body>
<div class="container">

  <div class="header">
    <h1>{{title}}</h1>
    <div class="header-meta">
      <span>{{analysis_time}}</span>
      <span><span class="badge badge-{{severityClass}}">{{severity}}</span></span>
      <span><span class="badge {{#eq problem_type '代码问题'}}badge-code{{/eq}}{{#eq problem_type '环境问题'}}badge-env{{/eq}}{{#eq problem_type '混合'}}badge-mix{{/eq}}">{{problem_type}}</span></span>
      {{#if environment.deploy_env}}<span>{{environment.deploy_env}}</span>{{/if}}
    </div>
  </div>

  <div class="summary-box">
    <strong>根因概述：</strong>{{summary}}
  </div>

  <!-- 请求信息 -->
  {{#if request_info}}
  <div class="card">
    <div class="card-title"><span class="icon">#</span> 请求信息</div>
    <table class="req-table">
      {{#if request_info.method}}<tr><td>方法</td><td>{{request_info.method}}</td></tr>{{/if}}
      {{#if request_info.url}}<tr><td>URL</td><td><code>{{request_info.url}}</code></td></tr>{{/if}}
      {{#if request_info.params}}<tr><td>关键参数</td><td>{{request_info.params}}</td></tr>{{/if}}
      {{#if request_info.status_code}}<tr><td>响应状态</td><td>{{request_info.status_code}}</td></tr>{{/if}}
      {{#if request_info.response_preview}}<tr><td>响应预览</td><td><code>{{request_info.response_preview}}</code></td></tr>{{/if}}
    </table>
  </div>
  {{/if}}

  <!-- 异常堆栈解析 -->
  {{#if stack_trace}}
  <div class="card">
    <div class="card-title"><span class="icon">#</span> 异常堆栈解析</div>
    <table class="req-table" style="margin-bottom:16px">
      {{#if stack_trace.exception_type}}<tr><td>异常类型</td><td><code>{{stack_trace.exception_type}}</code></td></tr>{{/if}}
      {{#if stack_trace.exception_message}}<tr><td>异常消息</td><td><code>{{stack_trace.exception_message}}</code></td></tr>{{/if}}
      {{#if stack_trace.trigger_handler}}<tr><td>触发处理器</td><td><code>{{stack_trace.trigger_handler}}</code></td></tr>{{/if}}
      {{#if stack_trace.root_cause_frame}}<tr><td>根因帧</td><td><code>{{stack_trace.root_cause_frame}}</code></td></tr>{{/if}}
      {{#if stack_trace.note}}<tr><td>说明</td><td>{{stack_trace.note}}</td></tr>{{/if}}
    </table>

    {{#if stack_trace.call_chain}}
    <h4 style="font-size:14px; margin-bottom:8px;">调用链（从入口到根因）</h4>
    <ul class="chain">
      {{#each stack_trace.call_chain}}
      <li {{#if this.is_entry}}class="entry"{{/if}}>
        <strong {{#if this.is_root}}style="color:#ef4444"{{/if}}>{{this.class}}</strong>.{{this.method}} (line {{this.line}})
        <br><span style="color:#64748b;font-size:12px">{{this.description}}</span>
        {{#if this.error}}<br><span style="color:#ef4444;font-size:12px">{{this.error}}</span>{{/if}}
      </li>
      {{/each}}
    </ul>
    {{/if}}
  </div>
  {{/if}}

  <!-- 根因代码定位 -->
  {{#if code_location}}
  <div class="card">
    <div class="card-title"><span class="icon">#</span> 根因代码定位</div>
    {{#if code_location.file}}
    <p style="font-size:13px;color:var(--text-secondary);margin-bottom:8px;">
      <code>{{code_location.file}}</code>
    </p>
    {{/if}}
    {{#if code_location.snippet}}
    <pre>{{code_location.snippet}}</pre>
    {{/if}}
    {{#if code_location.analysis}}
    <p style="font-size:14px;margin-top:16px;"><strong>问题分析：</strong></p>
    <p style="font-size:13px;color:var(--text-secondary);margin-top:4px;">{{code_location.analysis}}</p>
    {{/if}}
    {{#if code_location.evidence}}
    <div class="risk-box" style="margin-top:16px;">
      <strong>环境证据：</strong> {{code_location.evidence}}
      {{#if code_location.evidence_code}}
      <pre style="margin-top:8px">{{code_location.evidence_code}}</pre>
      {{/if}}
    </div>
    {{/if}}
  </div>
  {{/if}}

  <!-- 修复建议 -->
  {{#if fix_suggestions}}
  <div class="card">
    <div class="card-title"><span class="icon">#</span> 修复建议</div>
    <p style="font-size:12px;color:var(--text-secondary);margin-bottom:12px;">以下建议基于 AI 分析，仅供参考。</p>
    {{#each fix_suggestions}}
    <div class="fix-item">
      <h4><span class="priority-tag p{{priority}}">P{{priority}} {{priority_label}}</span> {{title}}</h4>
      {{#if location}}<p><strong>位置：</strong> {{location}}</p>{{/if}}
      {{#if action}}<p><strong>修改：</strong> {{action}}</p>{{/if}}
      {{#if detail}}<pre>{{detail}}</pre>{{/if}}
      {{#if reason}}<p><strong>原因：</strong> {{reason}}</p>{{/if}}
    </div>
    {{/each}}
  </div>
  {{/if}}

  <!-- 环境信息 -->
  <div class="card">
    <div class="card-title"><span class="icon">#</span> 环境信息</div>
    <table class="req-table">
      {{#if environment.java_version}}<tr><td>JDK 版本</td><td>{{environment.java_version}}</td></tr>{{/if}}
      {{#if environment.framework}}<tr><td>框架</td><td>{{environment.framework}}</td></tr>{{/if}}
      {{#if environment.deploy_env}}<tr><td>部署环境</td><td>{{environment.deploy_env}}</td></tr>{{/if}}
      {{#if environment.source_ref}}<tr><td>源码参考</td><td>{{environment.source_ref}}</td></tr>{{/if}}
    </table>
  </div>

  <div class="footer">
    Generated by qa-flow code-analysis skill &middot; {{analysis_time}}
  </div>

</div>
</body>
</html>
